generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ============================================================================
// Core User and Group Models
// ============================================================================

model User {
  id                         String                      @id @default(cuid())
  email                      String                      @unique
  name                       String
  username                   String?                     @unique
  usernameChangedAt          DateTime?
  passwordHash               String?
  emailVerified              Boolean                     @default(false)
  emailVerificationToken     String?                     @unique
  avatarUrl                  String?
  theme                      String                      @default("dark")
  showEmail                  Boolean                     @default(false)
  onboardingDone             Boolean                     @default(false)
  createdAt                  DateTime                    @default(now())
  updatedAt                  DateTime                    @updatedAt

  // Relations
  memberships                Membership[]
  eventsCreated              Event[]
  rsvps                      RSVP[]
  eventInvitesSent           EventInvite[]               @relation("invitedBy")
  eventInvitesReceived       EventInvite[]               @relation("invitedUser")
  messagesCreated            Message[]
  channelSubscriptions       ChannelSubscription[]
  channelReadStates          ChannelReadState[]
  userTagPrefs               UserTagPreference[]
  mediaAssets                MediaAsset[]
  mediaAlbums                MediaAlbum[]
  notificationSubscriptions  NotificationSubscription[]
  notificationEvents         NotificationEvent[]
  reactions                  MessageReaction[]
  notificationPreferences    UserNotificationPreference[]
  betaCodesUsed              BetaCode[]
  passwordResetTokens        PasswordResetToken[]
  auditLogsActed             AuditLog[]                  @relation("AuditActor")
  auditLogsTargeted          AuditLog[]                  @relation("AuditTarget")
  eventRatings               EventRating[]
  mediaAssetLikes            MediaAssetLike[]
  mutedUsers                 UserMute[]                  @relation("MuterMutes")
  mutedBy                    UserMute[]                  @relation("MutedByOthers")
  calendarPreferences        UserCalendarPreference[]

  @@index([email])
  @@index([username])
}

model Group {
  id          String        @id @default(cuid())
  name        String
  ownerId     String
  description String?
  avatarUrl   String?
  calendarToken String?     @unique
  inviteCode  String?       @unique
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  // Media upload settings
  mediaUploadEnabled         Boolean @default(false)
  mediaStorageLimitBytes     Int     @default(104857600)   // 100 MB default, max 1 GB
  mediaUploadNonAdminEnabled Boolean @default(true)       // false = admins/owners only

  // Feature toggles
  statsEnabled               Boolean @default(false)      // when true, all members can view group stats

  // Relations
  memberships         Membership[]
  events              Event[]
  channels            Channel[]
  tags                Tag[]
  auditLogs           AuditLog[]
  calendarPreferences UserCalendarPreference[]
  mediaAlbums         MediaAlbum[]

  @@index([ownerId])
}

model Membership {
  id        String   @id @default(cuid())
  userId    String
  groupId   String
  role      String   @default("member")  // owner, admin, member
  status    String   @default("active")  // active, pending
  mutedUntil DateTime?                   // null = not muted; future date = muted until then
  calendarToken String? @unique          // legacy per-user ICS feed token
  notifyUntaggedEvents Boolean @default(true)
  createdAt DateTime @default(now())

  // Relations
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
  @@index([groupId])
  @@index([groupId, status])
}

// ============================================================================
// Event Models
// ============================================================================

model Event {
  id              String         @id @default(cuid())
  groupId         String
  createdById     String
  title           String
  details         String?
  dateTime        DateTime
  endsAt          DateTime?
  isPrivate       Boolean        @default(false)
  maxAttendees    Int?
  location        String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  isLegendary     Boolean        @default(false)

  // Relations
  group           Group          @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdBy       User           @relation(fields: [createdById], references: [id], onDelete: SetNull, onUpdate: Cascade)
  rsvps           RSVP[]
  invites         EventInvite[]
  messages        Message[]
  mediaAssets     MediaAsset[]
  tags            Tag[]          @relation("EventTags")
  notificationEvents NotificationEvent[] @relation("eventNotifications")
  ratings         EventRating[]

  @@index([groupId])
  @@index([createdById])
  @@index([dateTime])
}

model RSVP {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  status    String   @default("no")  // yes, no, maybe
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
}

model EventRating {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  value     Int      // 1-5
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  event Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
}

model EventInvite {
  id        String   @id @default(cuid())
  eventId   String
  userId    String
  invitedById String
  createdAt DateTime @default(now())

  // Relations
  event        Event @relation(fields: [eventId], references: [id], onDelete: Cascade)
  invitedUser  User  @relation("invitedUser", fields: [userId], references: [id], onDelete: Cascade)
  invitedBy    User  @relation("invitedBy", fields: [invitedById], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@unique([eventId, userId])
  @@index([eventId])
  @@index([userId])
}

// ============================================================================
// Channel and Messaging Models
// ============================================================================

model Channel {
  id            String   @id @default(cuid())
  groupId       String
  name          String
  isInviteOnly  Boolean  @default(false)
  isGeneral     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  group         Group    @relation(fields: [groupId], references: [id], onDelete: Cascade)
  subscriptions  ChannelSubscription[]
  messages       Message[]
  tags           Tag[]             @relation("ChannelTags")
  readStates     ChannelReadState[]

  @@index([groupId])
  @@unique([groupId, name])
}

model ChannelSubscription {
  id        String   @id @default(cuid())
  userId    String
  channelId String
  createdAt DateTime @default(now())

  // Relations
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@unique([userId, channelId])
  @@index([channelId])
}

model Message {
  id        String   @id @default(cuid())
  eventId   String?
  channelId String?
  userId    String
  content   String
  pinned    Boolean  @default(false)
  replyToId String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  event     Event?            @relation(fields: [eventId], references: [id], onDelete: Cascade)
  channel   Channel?          @relation(fields: [channelId], references: [id], onDelete: Cascade)
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  reactions MessageReaction[]
  replyTo   Message?          @relation("MessageReplies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies   Message[]         @relation("MessageReplies")

  @@index([eventId])
  @@index([channelId])
  @@index([userId])
  @@index([createdAt])
  @@index([replyToId])
}

model ChannelReadState {
  userId     String
  channelId  String
  lastReadAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel Channel @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@id([userId, channelId])
  @@index([channelId])
}

model MessageReaction {
  id        String   @id @default(cuid())
  messageId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())

  // Relations
  message   Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
}

// ============================================================================
// Tag and Notification Preference Models
// ============================================================================

model Tag {
  id               String              @id @default(cuid())
  groupId          String
  name             String
  color            String?
  createdAt        DateTime            @default(now())

  // Relations
  group            Group               @relation(fields: [groupId], references: [id], onDelete: Cascade)
  events           Event[]              @relation("EventTags")
  channels         Channel[]            @relation("ChannelTags")
  userPreferences  UserTagPreference[]

  @@unique([groupId, name])
  @@index([groupId])
}

model UserTagPreference {
  id         String   @id @default(cuid())
  userId     String
  tagId      String
  subscribed Boolean  @default(true)
  createdAt  DateTime @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([userId, tagId])
  @@index([userId])
}

// ============================================================================
// User Notification Preference Model
// ============================================================================

model UserNotificationPreference {
  id                    String   @id @default(cuid())
  userId                String
  type                  String   // chat_message, event_created, event_changed, invite, rsvp_update, event_start, mention
  channel               String   // push, email, in_app
  enabled               Boolean  @default(true)
  reminderOffsetMinutes Int?     // event_start only: 15, 60, or 1440; null = default (15 min)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  // Relations
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type, channel])
  @@index([userId])
}

// ============================================================================
// Media and Push Notification Models
// ============================================================================

model MediaAsset {
  id         String   @id @default(cuid())
  eventId    String
  uploaderId String
  url        String
  filename   String
  sizeBytes  Int
  mimeType   String
  width      Int?
  height     Int?
  exifData   Json?
  caption    String?
  createdAt  DateTime @default(now())

  // Relations
  event          Event              @relation(fields: [eventId], references: [id], onDelete: Cascade)
  uploader       User               @relation(fields: [uploaderId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  likes          MediaAssetLike[]
  albumAssets    MediaAlbumAsset[]
  albumCoverOf   MediaAlbum[]       @relation("AlbumCover")

  @@index([eventId])
  @@index([uploaderId])
}

model MediaAlbum {
  id           String   @id @default(cuid())
  groupId      String
  name         String
  description  String?
  createdById  String?
  coverAssetId String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  group      Group          @relation(fields: [groupId], references: [id], onDelete: Cascade)
  createdBy  User?          @relation(fields: [createdById], references: [id], onDelete: SetNull)
  coverAsset MediaAsset?    @relation("AlbumCover", fields: [coverAssetId], references: [id], onDelete: SetNull)
  assets     MediaAlbumAsset[]

  @@index([groupId])
}

model MediaAlbumAsset {
  albumId String
  assetId String
  addedAt DateTime @default(now())

  album MediaAlbum @relation(fields: [albumId], references: [id], onDelete: Cascade)
  asset MediaAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@id([albumId, assetId])
  @@index([albumId])
  @@index([assetId])
}

model MediaAssetLike {
  id      String   @id @default(cuid())
  assetId String
  userId  String
  createdAt DateTime @default(now())

  // Relations
  asset MediaAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  user  User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([assetId, userId])
  @@index([assetId])
  @@index([userId])
}

model NotificationSubscription {
  id        String   @id @default(cuid())
  userId    String   @unique
  endpoint  String
  authSecret String
  p256dh    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model NotificationEvent {
  id          String   @id @default(cuid())
  type        String   // chat_message, event_created, event_changed, invite, rsvp_update
  recipientId String
  eventId     String?
  title       String
  body        String
  url         String?  // deep-link path (e.g. /events/:id, /groups/:id/channels/:id)
  createdAt   DateTime @default(now())
  readAt      DateTime?
  sentAt      DateTime?

  // Relations
  recipient User    @relation(fields: [recipientId], references: [id], onDelete: Cascade)
  event     Event?  @relation("eventNotifications", fields: [eventId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([recipientId])
  @@index([type])
  @@index([createdAt])
  @@index([recipientId, createdAt(sort: Desc)])
}

// ============================================================================
// Beta Access Codes
// ============================================================================

model BetaCode {
  id          String    @id @default(cuid())
  code        String    @unique
  type        String    // "registration" | "group_creation" | "invite_link"
  usedById    String?
  usedAt      DateTime?
  expiresAt   DateTime?
  singleUse   Boolean   @default(false)
  createdAt   DateTime  @default(now())

  // Relations
  usedBy User? @relation(fields: [usedById], references: [id], onDelete: SetNull)

  @@index([code])
  @@index([type])
}

// ============================================================================
// Password Reset
// ============================================================================

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model AuditLog {
  id           String   @id @default(cuid())
  groupId      String
  actorId      String
  action       String   // member_approved, member_denied, member_removed, role_changed, member_joined
  targetUserId String?
  meta         Json?
  createdAt    DateTime @default(now())

  // Relations
  group      Group  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  actor      User   @relation("AuditActor", fields: [actorId], references: [id], onDelete: Cascade)
  targetUser User?  @relation("AuditTarget", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([groupId, createdAt(sort: Desc)])
  @@index([actorId])
}

// ============================================================================
// User Mutes (per-user notification silencing)
// ============================================================================

// ============================================================================
// Per-user calendar feed preferences
// ============================================================================

model UserCalendarPreference {
  id            String   @id @default(cuid())
  userId        String
  groupId       String
  filterMode    String   @default("all")  // "all" | "rsvp" | "tags"
  tagIds        String   @default("")     // comma-joined tag IDs
  calendarToken String   @unique

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  group Group @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([userId, groupId])
  @@index([userId])
  @@index([calendarToken])
}

model UserMute {
  id        String   @id @default(cuid())
  muterId   String   // user doing the muting
  mutedId   String   // user being muted
  createdAt DateTime @default(now())

  // Relations
  muter User @relation("MuterMutes", fields: [muterId], references: [id], onDelete: Cascade)
  muted User @relation("MutedByOthers", fields: [mutedId], references: [id], onDelete: Cascade)

  @@unique([muterId, mutedId])
  @@index([muterId])
  @@index([mutedId])
}
